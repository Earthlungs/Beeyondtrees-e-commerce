generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("merchant")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id               String      @id @default(cuid())
  name             String
  description      String      @db.Text
  category         String
  retailPrice      Float
  wholesalePrice   Float
  distributorPrice Float
  stock            Int         @default(0)
  images           Json        @default("[]")
  isOnOffer        Boolean     @default(false)
  offerPrice       Float?
  isFeatured       Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  orderItems       OrderItem[]
}

model Order {
  id                   String      @id @default(cuid())
  customerName         String
  customerPhone        String
  customerEmail        String?
  county               String
  town                 String
  landmark             String?
  deliveryInstructions String?     @db.Text
  total                Float
  status               String      @default("pending")
  paymentRef           String?
  paymentStatus        String?
  transactionRef       String?
  // Sales channel: "online" (web checkout) or "pos" (physical shop till).
  // Both decrement the same Product.stock, so the two storefronts stay in sync.
  channel              String      @default("online")
  // POS-only fields. paymentMethod is "cash" | "mpesa" | "card".
  paymentMethod        String?
  cashReceived         Float?      // amount tendered for cash sales (for change)
  mpesaCode            String?     // M-Pesa confirmation code
  cardRef              String?     // card/terminal reference
  soldBy               String?     // name of the cashier who rang up the sale
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  items                OrderItem[]
  dispatch             Dispatch?
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  price       Float
  quantity    Int
  pricingTier String
  subtotal    Float
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
}

model Dispatch {
  id                String   @id @default(cuid())
  orderId           String   @unique
  riderName         String
  riderPhone        String
  motorbikePlate    String
  riderIdNo         String
  dispatchedAt      DateTime @default(now())
  estimatedDelivery DateTime?
  createdAt         DateTime @default(now())
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
